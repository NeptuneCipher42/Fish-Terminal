{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#BD93F9",
    "template": "{{ if gt .Code 0 }}💀{{ else }}🦈{{ end }} ❯ "
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "\ue0b0",
          "foreground": "#0B1220",
          "background": "#FF79C6",
          "template": " 🦈 {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "diamond",
          "leading_diamond": "\ue0b0",
          "trailing_diamond": "\ue0b0",
          "foreground": "#0B1220",
          "background": "#BD93F9",
          "properties": {
            "style": "agnoster",
            "max_depth": 3,
            "home_icon": "~"
          },
          "template": " \ue5fe {{ .Path }} "
        },
        {
          "type": "git",
          "style": "diamond",
          "leading_diamond": "\ue0b0",
          "trailing_diamond": "\ue0b0",
          "foreground": "#0B1220",
          "background": "#FF79C6",
          "background_templates": [
            "{{ if or .Working.Changed .Staging.Changed }}#FF5555{{ end }}"
          ],
          "properties": {
            "fetch_status": false
          },
          "template": " {{ .HEAD }}{{ if .Working.Changed }} ~{{ end }}{{ if .Staging.Changed }} +{{ end }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "time",
          "style": "diamond",
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "\ue0b0",
          "foreground": "#0B1220",
          "background": "#BD93F9",
          "template": " \uf017 {{ .CurrentDate | date \"3:04 PM\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "exit",
          "style": "plain",
          "foreground": "#BD93F9",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FF5555{{ end }}"
          ],
          "template": "{{ if gt .Code 0 }}💀 ❯ {{ else }}🦈 ❯ {{ end }}"
        }
      ]
    }
  ]
}
