{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#0B1220",
          "background": "#FF79C6",
          "template": " 🦈 {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#5FD7FF",
          "background": "#0D2137",
          "properties": {
            "style": "agnoster",
            "max_depth": 3,
            "home_icon": "~"
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#0B1220",
          "background": "#FF79C6",
          "background_templates": [
            "{{ if and (gt .Behind 0) (gt .Ahead 0) }}#FF5555{{ end }}",
            "{{ if gt .Behind 0 }}#FFB86C{{ end }}",
            "{{ if gt .Ahead 0 }}#5FD7FF{{ end }}",
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#FF00A0{{ end }}"
          ],
          "properties": {
            "fetch_status": true
          },
          "template": " {{ .HEAD }}{{ if .Working.Changed }} ~{{ end }}{{ if .Staging.Changed }} +{{ end }}{{ if gt .Behind 0 }} ↓{{ .Behind }}{{ end }}{{ if gt .Ahead 0 }} ↑{{ .Ahead }}{{ end }} "
        },
        {
          "type": "time",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#0B1220",
          "background": "#5FD7FF",
          "template": "  {{ .CurrentDate | date \"15:04\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "exit",
          "style": "plain",
          "foreground": "#50FA7B",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FF5555{{ end }}"
          ],
          "template": "{{ if gt .Code 0 }}💀 ❯ {{ else }}🦈 ❯ {{ end }}"
        }
      ]
    }
  ]
}
