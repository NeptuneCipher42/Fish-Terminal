{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#50FA7B",
    "foreground_templates": ["{{ if gt .Code 0 }}#FF5555{{ end }}"],
    "template": "{{ if gt .Code 0 }}💀{{ else }}🦈{{ end }} ❯ "
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\uE0B0",
          "foreground": "#0A0F1E",
          "background": "#00FF9C",
          "template": " 🦈 {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\uE0B0",
          "foreground": "#5FD7FF",
          "background": "#0D2137",
          "properties": {
            "style": "agnoster",
            "max_depth": 3,
            "home_icon": "~"
          },
          "template": "  {{ .Path }} "
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\uE0B0",
          "foreground": "#0A0F1E",
          "background": "#00FF9C",
          "background_templates": [
            "{{ if and (gt .Behind 0) (gt .Ahead 0) }}#FF5555{{ end }}",
            "{{ if gt .Behind 0 }}#FFB86C{{ end }}",
            "{{ if gt .Ahead 0 }}#00B4D8{{ end }}",
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#FF79C6{{ end }}"
          ],
          "properties": {
            "fetch_status": true
          },
          "template": "  {{ .HEAD }}{{ if .Working.Changed }} ~{{ end }}{{ if .Staging.Changed }} \u271A{{ end }}{{ if gt .Behind 0 }} \u2193{{ .Behind }}{{ end }}{{ if gt .Ahead 0 }} \u2191{{ .Ahead }}{{ end }} "
        },
        {
          "type": "executiontime",
          "style": "powerline",
          "powerline_symbol": "\uE0B0",
          "foreground": "#0A0F1E",
          "background": "#BD93F9",
          "properties": {
            "threshold": 2000
          },
          "template": "  {{ .FormattedMs }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "time",
          "style": "plain",
          "foreground": "#FFB86C",
          "template": "  {{ .CurrentDate | date \"15:04\" }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "exit",
          "style": "plain",
          "foreground": "#50FA7B",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#FF5555{{ end }}"
          ],
          "template": "{{ if gt .Code 0 }}\uD83D\uDC80 \u276F {{ else }}\uD83E\uDD88 \u276F {{ end }}"
        }
      ]
    }
  ]
}
