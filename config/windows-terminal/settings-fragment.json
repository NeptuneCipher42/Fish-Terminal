{
  "$schema": "https://raw.githubusercontent.com/microsoft/terminal/main/doc/cascadia/TerminalSettingsSchema.json",
  "profiles": {
    "defaults": {
      "font": {
        "face": "CaskaydiaCove Nerd Font",
        "size": 11,
        "weight": "normal"
      },
      "antialiasingMode": "cleartype",
      "bellStyle": "none",
      "cursorShape": "bar",
      "useAtlasEngine": true,
      "colorScheme": "Shark Dark"
    }
  },
  "schemes": [
    {
      "name": "Shark Dark",
      "background": "#0B1220",
      "foreground": "#F8F8F2",
      "cursorColor": "#FF79C6",
      "selectionBackground": "#44475A80",
      "black": "#21222C",
      "red": "#FF5555",
      "green": "#50FA7B",
      "yellow": "#F1FA8C",
      "blue": "#BD93F9",
      "purple": "#FF79C6",
      "cyan": "#8BE9FD",
      "white": "#F8F8F2",
      "brightBlack": "#6272A4",
      "brightRed": "#FF6E6E",
      "brightGreen": "#69FF7D",
      "brightYellow": "#FFFFA5",
      "brightBlue": "#D6ACFF",
      "brightPurple": "#FF92DF",
      "brightCyan": "#A4FFFF",
      "brightWhite": "#FFFFFF"
    }
  ]
}
